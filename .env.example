# Database — local dev uses SQLite (file-based, no server needed).
# For Postgres in production, switch the datasource provider in
# prisma/schema.prisma to "postgresql" and use a postgres:// URL here.
DATABASE_URL="file:./dev.db"

# Stripe (test mode, added in a later phase)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# NextAuth (added in a later phase)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
